<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd
    http://www.w3.org/1999/xhtml http://www.w3.org/2002/08/xhtml/xhtml1-strict.xsd"
    xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
    xmlns:xhtml="http://www.w3.org/1999/xhtml" >
  {% for post in site.posts %}
    {% if post.lang %}
      {% for lang in site.languages %}
        {% if lang == 'ja' %}
          <url>
            <loc>{{ site.url }}/en{{ post.url | replace: 'index.html', '' }}</loc>
            <xhtml:link
                    rel="alternate"
                    hreflang="ja"
                    href=" {{ site.url }}{{ post.url | replace: 'index.html', '' }}"/>
            <xhtml:link
                    rel="alternate"
                    hreflang="ko"
                    href="{{ site.url }}/ko{{ post.url | replace: 'index.html', '' }}"/>

            <lastmod>{{ post.last_modified_at | date: '%Y-%m-%d' }}</lastmod>
            <priority>1.0</priority>
          </url>
          <url>
            <loc>{{ site.url }}{{ post.url | replace: 'index.html', '' }}</loc>
            <xhtml:link
                    rel="alternate"
                    hreflang="en"
                    href="{{ site.url }}/en{{ post.url | replace: 'index.html', '' }}"/>
            <xhtml:link
                    rel="alternate"
                    hreflang="ko"
                    href="{{ site.url }}/ko{{ post.url | replace: 'index.html', '' }}"/>

            <lastmod>{{ post.last_modified_at | date: '%Y-%m-%d' }}</lastmod>
            <priority>1.0</priority>
          </url>
          <url>
            <loc>{{ site.url }}/ko{{ post.url | replace: 'index.html', '' }}</loc>
            <xhtml:link
                    rel="alternate"
                    hreflang="ja"
                    href=" {{ site.url }}{{ post.url | replace: 'index.html', '' }}"/>
            <xhtml:link
                    rel="alternate"
                    hreflang="en"
                    href="{{ site.url }}/en{{ post.url | replace: 'index.html', '' }}"/>

            <lastmod>{{ post.last_modified_at | date: '%Y-%m-%d' }}</lastmod>
            <priority>1.0</priority>
          </url>
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% for page in site.pages %}
  {% if page.lang %}
  {% for lang in site.languages %}
    {% if page.permalink contains '.json' %}
    {% else %}
    <url>
      {% if lang == site.default_lang %}
      <loc>{{ site.url }}{{ page.url | replace: 'index.html', '' }}</loc>
      {% else %}
      <loc>{{ site.url }}/{{lang}}{{ page.url | replace: 'index.html', '' }}</loc>
      {% endif %}
      <lastmod>{{ site.time | date: '%Y-%m-%d' }}</lastmod>
      <priority>0.5</priority>
    </url>
    {% endif %}
  {% endfor %}
  {% endif %}
  {% endfor %}

